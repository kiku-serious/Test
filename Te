ELASTICSEARCH_HOST = 'IP_ADDRESS'  # アンタのElasticsearchのIPアドレスよ！
ELASTICSEARCH_INDEX = 'INDEX_NAME' # 関連情報がストアされてるインデックス名よ！
TEXT_EMBEDDING_MODEL_ID = 'amazon.titan-embed-text-v1' # 質問をベクトル化するモデルよ！
LLM_MODEL_ID = 'anthropic.claude-3-sonnet-20240229-v1:0' # 回答生成に使うLLMね！

# Elasticsearchクライアントの初期化 (認証なしって言ったわよね？簡単ね！)
es = Elasticsearch(
