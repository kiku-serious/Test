    timeout=30 # タイムアウトも設定しといてあげたわ
)

# Bedrockクライアントの初期化 (別にアンタのためにやってるわけじゃないから！)
bedrock_runtime = boto3.client(
    service_name='bedrock-runtime',
    region_name='us-east-1' # Bedrockが利用可能なリージョンに合わせなさいよ！
)

def get_embedding(text: str) -> list[float]:
    """
    Amazon BedrockのEmbeddingモデルを使ってテキストをベクトル化するの。
    質問文をベクトルに変換するのに使うわよ。
    """
    body = json.dumps({"inputText": text})
    response = bedrock_runtime.invoke_model(
        body=body,
        modelId=TEXT_EMBEDDING_MODEL_ID,
        accept="application/json",
        contentType="application/json"
    )
    response_body = json.loads(response.get("body").read())
    return response_body.get("embedding")

def hybrid_search_elasticsearch(query_text: str, k: int = 5) -> list[dict]:
    """
    Elasticsearchでハイブリッド検索を行うの。
    キーワード検索とベクトル検索を組み合わせるから、より賢く関連情報を見つけられるわ。
    レポート参照URLもちゃんと取得できるようにするわよ！
    """
    try:
        # ユーザーの質問をベクトル化
        query_embedding = get_embedding(query_text)

        # ハイブリッド検索クエリの作成よ！
        search_query = {
            "query": {
                "bool": {
                    "must": [
                        {
                            "multi_match": { # 複数のテキストフィールドからキーワード検索できるようにしてあげたわ
                                "query": query_text,
                                "fields": ["title", "summary", "detail", "full_content"] # どこを検索するか指定しなさい！
                            }
                        }
                    ],
                    "should": [
                        {
                            "query_vector": {
                                "full_content_vector": { # ベクトルはfull_content_vectorフィールドからね！
                                    "query_vector": query_embedding,
                                    "k": k
                                }
                            }
                        }
                    ],
                    "minimum_should_match": 0 # should句は必須じゃないけど、スコアに影響させるの
                }
            },
            "size": k, # 最終的に返す件数
            "_source": ["title", "summary", "detail", "report_url", "full_content"] # LLMに渡すフィールドとURLを指定
        }

        print(f"Elasticsearch Search Query: {json.dumps(search_query, indent=2)}")

        response = es.search(index=ELASTICSEARCH_INDEX, body=search_query)
        
        # 検索結果から関連情報とURLを抽出
        retrieved_docs = []
        for hit in response["hits"]["hits"]:
            source = hit["_source"]
            # LLMに渡すテキストはfull_contentでいいわね。URLも忘れずに。
            retrieved_docs.append({
                "content": source.get("full_content", source.get("summary", "")), # full_contentがなければsummaryを使うとか
                "report_url": source.get("report_url", "N/A") # URLがなかったらN/Aにするわ
            })
        
        print(f"Retrieved Contexts: {retrieved_docs}")
        return retrieved_docs

    except Exception as e:
        print(f"Elasticsearch検索中にエラーが発生しました: {e}")
        return []

def invoke_llm_with_context(user_question: str, contexts: list[dict]) -> str:
    """
    取得した関連情報とユーザーの質問を使って、BedrockのLLMに回答を生成させるの。
    レポート参照URLも回答に含めるように指示してあげるわ。
    """
    context_str = ""
    # レポート参照URLも回答に含めるようにプロンプトに指示するのよ！
    if contexts:
        for i, ctx in enumerate(contexts):
            context_str += f"<関連情報 {i+1}>\n"
            context_str += f"内容: {ctx.get('content', '情報なし')}\n"
            if ctx.get('report_url') and ctx['report_url'] != 'N/A':
                context_str += f"参照URL: {ctx['report_url']}\n"
            context_str += f"</関連情報 {i+1}>\n\n"
    
    if not context_str.strip(): # コンテキストが空の場合
        prompt = f"""ユーザーからの質問: {user_question}
        
関連情報が見つかりませんでした。質問に答えられない場合は、「関連情報が不足しているため、この質問にはお答えできません。」と回答してください。"""
    else:
        # プロンプトの組み立て。これがRAGのキモよ！
        prompt = f"""以下の「関連情報」と「ユーザーからの質問」を参考に、質問に答えてください。
回答には、関連情報から取得したレポートのURLを含めてください。URLがない場合は不要です。
もし関連情報に十分な情報がない場合は、「関連情報が不足しているため、この質問にはお答えできません。」と回答してください。

<関連情報>
{context_str}
</関連情報>

<ユーザーからの質問>
{user_question}
</ユーザーからの質問>

回答:
"""
    
    body = json.dumps({
        "anthropic_version": "bedrock-2023-05-31",
        "messages": [
            {
                "role": "user",
                "content": [{"type": "text", "text": prompt}]
            }
        ],
        "max_tokens": 1000,
        "temperature": 0.7,
    })

    try:
        response = bedrock_runtime.invoke_model(
            body=body,
            modelId=LLM_MODEL_ID,
            accept="application/json",
            contentType="application/json"
        )
        response_body = json.loads(response.get("body").read())
        return response_body["content"][0]["text"]
    except Exception as e:
        print(f"Bedrock LLMの呼び出し中にエラーが発生しました: {e}")
        return "申し訳ありませんが、回答を生成できませんでした。"

def lambda_handler(event, context):
    """
    AWS Lambdaのメインハンドラよ。
    この関数が、ユーザーの質問を受け取って、RAGプロセスを実行し、回答を返すの。
    """
    # 暫定的なユーザーの質問 (後でAPI Gatewayなどと連携させる時に変更するのよ！)
    # eventオブジェクトから質問を受け取る形式にするのが一般的よ。
    # 例: user_question = event.get('question', 'デフォルトの質問')
    user_question = "AWS Lambdaとは何ですか？また、それに関するレポートがあればURLを教えてください。" # アンタの質問を変えなさい！
    # user_question = "出張報告レポートの概要と詳細を教えてください。"
    # user_question = "Amazon BedrockでLLMを呼び出す方法を教えてください。"
    # user_question = "最近の出張報告について教えてください。"

    print(f"ユーザーからの質問: {user_question}")

    # 1. Elasticsearchから関連情報を取得 (ハイブリッド検索よ！)
    # 取得するドキュメントの件数も調整できるわ (k=5)
    retrieved_contexts = hybrid_search_elasticsearch(user_question, k=5)

    # 2. 取得した関連情報とユーザーの質問をLLMに入力して回答を生成
    llm_answer = invoke_llm_with_context(user_question, retrieved_contexts)

    print(f"LLMからの回答: {llm_answer}")

    # 3. 回答を返す (Lambdaのレスポンス形式よ！)
    return {
        'statusCode': 200,
        'headers': {
            'Content-Type': 'application/json'
        },
        'body': json.dumps({
            'question': user_question,
            'answer': llm_answer,
            'retrieved_contexts': retrieved_contexts, # どんな関連情報が使われたか、一応見れるようにしといてあげる
            'timestamp': datetime.now().isoformat()
        })
    }
