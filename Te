import json
import os
import boto3
from datetime import datetime

# Elasticsearchクライアントのインポート。これがないと動かないわよ！
from elasticsearch import Elasticsearch

# --- 設定値 (ここをちゃんと環境変数から読み込むようにするのよ！) ---
ELASTICSEARCH_HOST = os.environ.get('ELASTICSEARCH_HOST', 'IP_ADDRESS') # ElasticsearchのIPアドレスよ！
ELASTICSEARCH_INDEX = os.environ.get('ELASTICSEARCH_INDEX', 'INDEX_NAME') # 関連情報がストアされてるインデックス名ね！
TEXT_EMBEDDING_MODEL_ID = os.environ.get('TEXT_EMBEDDING_MODEL_ID', 'amazon.titan-embed-text-v1') # 質問をベクトル化するモデルよ！

# LLMの設定は環境変数で柔軟に指定できるようにするわ！
# 例: LLM_MODEL_ID='anthropic.claude-3-sonnet-20240229-v1:0'
# 例: LLM_MODEL_TYPE='anthropic'
# 例: LLM_MODEL_ID='mistral.mistral-7b-instruct-v0:2'
# 例: LLM_MODEL_TYPE='mistral'
LLM_MODEL_ID = os.environ.get('LLM_MODEL_ID', 'anthropic.claude-3-sonnet-20240229-v1:0')
LLM_MODEL_TYPE = os.environ.get('LLM_MODEL_TYPE', 'anthropic') # 'anthropic', 'mistral', 'amazon' など、LLMの種類に応じて切り替えるわ

# --- LLMプロンプトの定義 (ここを読めばプロンプトがわかるようにしてあげたわよ！) ---
# 関連情報が見つかった場合のプロンプトテンプレート
RAG_PROMPT_TEMPLATE = """以下の「関連情報」と「ユーザーからの質問」を参考に、質問に答えてください。
回答には、関連情報から取得したレポートのURLを含めてください。URLがない場合は不要です。
もし関連情報に十分な情報がない場合は、「関連情報が不足しているため、この質問にはお答えできません。」と回答してください。

<関連情報>
{context_str}
</関連情報>

<ユーザーからの質問>
{user_question}
</ユーザーからの質問>

回答:
"""

# 関連情報が見つからなかった場合のプロンプトテンプレート
NO_RAG_PROMPT_TEMPLATE = """ユーザーからの質問: {user_question}

関連情報が見つかりませんでした。質問に答えられない場合は、「関連情報が不足しているため、この質問にはお答えできません。」と回答してください。"""

# --- Elasticsearchクライアントの初期化 ---
es = Elasticsearch(
    hosts=[{'host': ELASTICSEARCH_HOST, 'port': 9200, 'scheme': 'http'}],
    timeout=30
)

# --- Bedrockクライアントの初期化 ---
bedrock_runtime = boto3.client(
    service_name='bedrock-runtime',
    region_name=os.environ.get('AWS_REGION', 'us-east-1') # AWS_REGIONも環境変数から取得するようにしておいたわ
)

def get_embedding(text: str) -> list[float]:
    """
    Amazon BedrockのEmbeddingモデルを使ってテキストをベクトル化するの。
    """
    body = json.dumps({"inputText": text})
    response = bedrock_runtime.invoke_model(
        body=body,
        modelId=TEXT_EMBEDDING_MODEL_ID,
        accept="application/json",
        contentType="application/json"
    )
    response_body = json.loads(response.get("body").read())
    return response_body.get("embedding")

def hybrid_search_elasticsearch(query_text: str, k: int = 5) -> list[dict]:
    """
    Elasticsearchでハイブリッド検索を行うの。
    """
    try:
        query_embedding = get_embedding(query_text)

        search_query = {
            "query": {
                "bool": {
                    "must": [
                        {
                            "multi_match": {
                                "query": query_text,
                                "fields": ["title", "summary", "detail", "full_content"]
                            }
                        }
                    ],
                    "should": [
                        {
                            "query_vector": {
                                "full_content_vector": {
                                    "query_vector": query_embedding,
                                    "k": k
                                }
                            }
                        }
                    ],
                    "minimum_should_match": 0
                }
            },
            "size": k,
            "_source": ["title", "summary", "detail", "report_url", "full_content"]
        }

        print(f"Elasticsearch Search Query: {json.dumps(search_query, indent=2)}")

        response = es.search(index=ELASTICSEARCH_INDEX, body=search_query)
        
        retrieved_docs = []
        for hit in response["hits"]["hits"]:
            source = hit["_source"]
            retrieved_docs.append({
                "content": source.get("full_content", source.get("summary", "")),
                "report_url": source.get("report_url", "N/A")
            })
        
        print(f"Retrieved Contexts: {retrieved_docs}")
        return retrieved_docs

    except Exception as e:
        print(f"Elasticsearch検索中にエラーが発生しました: {e}")
        return []

def invoke_llm_with_context(user_question: str, contexts: list[dict]) -> str:
    """
    取得した関連情報とユーザーの質問を使って、BedrockのLLMに回答を生成させるの。
    LLM_MODEL_TYPEに応じてプロンプトとbodyを生成するわよ！
    """
    context_str = ""
    if contexts:
        for i, ctx in enumerate(contexts):
            context_str += f"<関連情報 {i+1}>\n"
            context_str += f"内容: {ctx.get('content', '情報なし')}\n"
            if ctx.get('report_url') and ctx['report_url'] != 'N/A':
                context_str += f"参照URL: {ctx['report_url']}\n"
            context_str += f"</関連情報 {i+1}>\n\n"
    
    # コンテキストの有無でプロンプトを切り替えるわ
    if not context_str.strip():
        prompt = NO_RAG_PROMPT_TEMPLATE.format(user_question=user_question)
    else:
        prompt = RAG_PROMPT_TEMPLATE.format(context_str=context_str, user_question=user_question)

    # LLMのモデルタイプに応じてリクエストボディを構築するのよ！
    # これでAnthropic以外も柔軟に対応できるでしょ？
    body = {}
    if LLM_MODEL_TYPE == 'anthropic':
        body = json.dumps({
            "anthropic_version": "bedrock-2023-05-31",
            "messages": [
                {
                    "role": "user",
                    "content": [{"type": "text", "text": prompt}]
                }
            ],
            "max_tokens": 1000,
            "temperature": 0.7,
        })
    elif LLM_MODEL_TYPE == 'mistral':
        body = json.dumps({
            "prompt": f"<s>[INST] {prompt} [/INST]", # Mistralのインストラクション形式に合わせるわ
            "max_tokens": 1000,
            "temperature": 0.7,
        })
    elif LLM_MODEL_TYPE == 'amazon': # 例えばAmazon Titan Text Express/Lite V1の場合
        body = json.dumps({
            "inputText": prompt,
            "textGenerationConfig": {
                "maxTokenCount": 1000,
                "temperature": 0.7,
            }
        })
    else:
        # 未知のモデルタイプならエラーを出すか、デフォルトの形式で試すか。今回はエラーを出すわ
        print(f"エラー: 未知のLLM_MODEL_TYPE: {LLM_MODEL_TYPE}")
        return "申し訳ありませんが、設定されたLLMモデルタイプに対応できません。"

    try:
        response = bedrock_runtime.invoke_model(
            body=body,
            modelId=LLM_MODEL_ID,
            accept="application/json",
            contentType="application/json"
        )
        response_body = json.loads(response.get("body").read())
        
        # モデルタイプによってレスポンスのパース方法も変わるから注意よ！
        if LLM_MODEL_TYPE == 'anthropic':
            return response_body["content"][0]["text"]
        elif LLM_MODEL_TYPE == 'mistral':
            return response_body["outputs"][0]["text"]
        elif LLM_MODEL_TYPE == 'amazon':
            return response_body["results"][0]["outputText"]
        else:
            return "申し訳ありませんが、回答を解析できませんでした。"

    except Exception as e:
        print(f"Bedrock LLMの呼び出し中にエラーが発生しました: {e}")
        return "申し訳ありませんが、回答を生成できませんでした。"

def lambda_handler(event, context):
    """
    AWS Lambdaのメインハンドラよ。
    """
    # 暫定的なユーザーの質問 (API Gatewayと連携させる時に変更するのよ！)
    user_question = "AWS Lambdaとは何ですか？また、それに関するレポートがあればURLを教えてください。"

    print(f"ユーザーからの質問: {user_question}")

    retrieved_contexts = hybrid_search_elasticsearch(user_question, k=5)

    llm_answer = invoke_llm_with_context(user_question, retrieved_contexts)

    print(f"LLMからの回答: {llm_answer}")

    return {
        'statusCode': 200,
        'headers': {
            'Content-Type': 'application/json'
        },
        'body': json.dumps({
            'question': user_question,
            'answer': llm_answer,
            'retrieved_contexts': retrieved_contexts,
            'timestamp': datetime.now().isoformat()
        })
    }
