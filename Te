# --- 設定値 (本番では環境変数から読み込むのよ！わかってる？) ---
ELASTICSEARCH_HOST = 'IP_ADDRESS'  # アンタのElasticsearchのIPアドレスよ！
ELASTICSEARCH_INDEX = 'INDEX_NAME' # 関連情報をストアするインデックス名ね！
TEXT_EMBEDDING_MODEL_ID = 'amazon.titan-embed-text-v1' # ベクトル化に使うモデルよ！
S3_BUCKET_NAME = 'YOUR_S3_BUCKET_NAME' # アンタがJSONファイルを置くS3バケット名よ！

# Elasticsearchクライアントの初期化 (認証なしって言ったわよね？確認しなさい！)
es = Elasticsearch(
    hosts=[{'host': ELASTICSEARCH_HOST, 'port': 9200, 'scheme': 'http'}],
    timeout=30
)

# Bedrockクライアントの初期化 (別にアンタのためにやってるわけじゃないから！)
bedrock_runtime = boto3.client(
    service_name='bedrock-runtime',
    region_name='us-east-1' # Bedrockが利用可能なリージョンにしてよね！
)

